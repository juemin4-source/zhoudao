    {"name":"赋值","pattern":"设名称为值。","python":"x = value","note":"用 为 分隔，无 ="},
    {"name":"无值","pattern":"设名称没有值。","python":"x = None"},
    {"name":"真值","pattern":"设名称成立。","python":"x = True"},
    {"name":"假值","pattern":"设名称不成立。","python":"x = False"},
    {"name":"变更","pattern":"使名称变为值。","python":"x = value"},
    {"name":"算术变更","pattern":"使名称加1。","python":"x += 1","variants":["减","乘","除"]},
    {"name":"命题变更","pattern":"使名称成立。","python":"x = True"},
    {"name":"打印","pattern":"显示【内容】。","python":"print('内容')"},
    {"name":"打印变量","pattern":"显示名称。","python":"print(名称)"},
    {"name":"条件","pattern":"如果条件，就动作，不然就动作。","python":"if cond: body else: body"},
    {"name":"elif","pattern":"如果条件，就动作，不然，如果条件2，就动作，不然就动作。","python":"if c1: body elif c2: body else: body"},
    {"name":"当循环","pattern":"当条件时，一直动作。","python":"while cond: body"},
    {"name":"遍历","pattern":"从集合中，每取一项记作名，就动作。","python":"for x in items: body"},
    {"name":"函数单表达式","pattern":"设名（参数）为表达式。","python":"def f(p): return expr"},
    {"name":"函数体","pattern":"定义名（参数）如下：动作。","python":"def f(p): body"},
    {"name":"返回","pattern":"以表达式为所得","python":"return expr"},
