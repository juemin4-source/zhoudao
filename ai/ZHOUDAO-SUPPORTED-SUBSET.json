{
  "schema_version": "0.1.0",
  "language": "周道",
  "description": "周道当前支持的 Python 子集",

  "supported_constructs": [
    "变量赋值与重新赋值",
    "算术运算（+ - * / // %）",
    "比较运算（== != < > <= >=）",
    "逻辑运算（且或非）",
    "条件分支（如果/否则/或者如果）",
    "循环（当循环 遍历）",
    "函数定义（功能 所得）",
    "显示输出（显示【】）",
    "字符串插值（{名称}）",
    "列表与映射字面量",
    "成员访问（.属性）",
    "模块引入（引入 从中引入）",
    "跨文件引用（引入周道源文件）",
    "精确名称（{中文名称}）"
  ],

  "unsupported_constructs": [
    "类别与面向对象",
    "异常捕获（尝试/报错）",
    "生成器与 yield",
    "异步（等待）",
    "装饰器",
    "类型注解",
    "with 语句（以所得）",
    "模式匹配（分情形）—— WIP",
    "切片语法",
    "列表推导式",
    "f-string（替代：显示【】插值）"
  ],

  "behavioral_differences": [
    {
      "feature": "print",
      "zhoudao": "显示【内容】。",
      "note": "自动在末尾换行。支持 {名称} 插值语法"
    },
    {
      "feature": "字符串",
      "zhoudao": "支持 \"\" 和 「」两种",
      "note": "「」是未正式冻结的语法，推荐优先使用 \"\""
    },
    {
      "feature": "标识符",
      "zhoudao": "支持中文标识符",
      "note": "使用 {精确名称} 防止分词歧义"
    }
  ]
}
